# ══════════════════════════════════════════════════
# TIỆM VIVU — Environment Variables
# Copy file này thành .env.local rồi điền giá trị thật
# KHÔNG commit .env.local lên GitHub
# ══════════════════════════════════════════════════

# Supabase — lấy ở Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Service Role Key (SECRET — không expose ra client)
SUPABASE_SERVICE_KEY=eyJhbGciOi...your-service-role-key

# Admin — mật khẩu đăng nhập admin
ADMIN_PASSWORD=your-strong-password-here

# JWT Secret — tự tạo chuỗi ngẫu nhiên dài 32+ ký tự
# Ví dụ: openssl rand -base64 32
JWT_SECRET=your-random-secret-at-least-32-chars-long
